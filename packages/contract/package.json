{
  "name": "@onwealth/contract",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint -c oxlint.config.mts",
    "lint:fix": "oxlint -c oxlint.config.mts --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "devDependencies": {
    "@onwealth/tsconfig": "workspace:*",
    "typescript": "catalog:"
  }
}

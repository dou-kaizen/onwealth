// HAND-WRITTEN — `@infra-x/tsconfig` tool unavailable (not in PATH; verified Phase 1).
// [H1 fallback] Mirrors packages/shared-kernel/tsconfig.json compiler options +
// NestJS decorator support (experimentalDecorators, emitDecoratorMetadata) and
// `nodenext` resolution to match the `.js`-extension relative import style.
{
  "compilerOptions": {
    "target": "esnext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.tsbuildinfo",
    "lib": ["esnext"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "types": ["node"],
    "noEmit": true
  },
  "include": ["src/**/*"]
}

{
  "name": "@onwealth/database",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "peerDependencies": {
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@onwealth/tsconfig": "workspace:*",
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "postgres": "catalog:",
    "typescript": "catalog:"
  }
}

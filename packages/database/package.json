{
  "name": "@boilerplate/database",
  "version": "1.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "db:init-roles": "tsx scripts/init-roles.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/pg": "catalog:",
    "dotenv": "catalog:",
    "drizzle-kit": "0.31.6",
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "tsdown": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "drizzle-orm": "0.44.7",
    "pg": "^8.16.3"
  }
}

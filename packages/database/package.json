{
  "name": "@onwealth/database",
  "version": "1.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "db:init-roles": "psql \"$DATABASE_URL\" -f sql/00-init-role-timeouts.sql",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/pg": "8.15.6",
    "dotenv": "^17.3.1",
    "drizzle-kit": "0.31.6",
    "drizzle-orm": "0.44.7",
    "pg": "8.16.3",
    "postgres": "^3.4.8",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "drizzle-orm": "0.44.7",
    "pg": "8.16.3",
    "postgres": "^3.4.8"
  }
}

{
  "name": "@onwealth/core",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "devDependencies": {
    "@onwealth/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}

{
  "name": "onwealth",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint && pnpm depcruise:check",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "deps": "turbo run deps",
    "clean": "turbo run clean",
    "depcruise:check": "depcruise packages apps --config .dependency-cruiser.cjs",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@infra-x/code-quality": "^0.6.2",
    "dependency-cruiser": "catalog:",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.9.7",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "@swc/core",
      "bcrypt",
      "esbuild",
      "lefthook"
    ]
  }
}

# EditorConfig - base editor configuration
# https://editorconfig.org

root = true

[*]
# Character encoding
charset = utf-8

# Line ending type
end_of_line = lf

# Insert a final newline at end of file
insert_final_newline = true

# Trim trailing whitespace
trim_trailing_whitespace = true

# Indentation
indent_style = space
indent_size = 2

# Maximum line length (reference value)
max_line_length = 100

{
  "extends": "@onwealth/tsconfig/nest.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}

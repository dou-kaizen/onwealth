# Required — no default. Production must override (boot fails on placeholder).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/onwealth
JWT_SECRET=replace-with-openssl-rand-hex-32-min-32-chars-long
API_BASE_URL=http://localhost:3000
# REDIS_URL is required in prod: cluster-safe throttler storage depends on it.
# Local dev default below is rejected when NODE_ENV=production.

# Optional — env schema defaults shown.
NODE_ENV=development
PORT=3000

# Pool sizing
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=10000

# Auth
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated origins; unset disables CORS (logs WARN)
ALLOWED_ORIGINS=

# Redis — cluster-safe throttler storage. MUST be reachable at boot;
# unreachable Redis fails fast (5s connect timeout) rather than degrading
# to permissive in-memory limits. Localhost default is rejected in prod.
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=300

# Request lifecycle
REQUEST_TIMEOUT_MS=30000

# Swagger gate (`true` | `false`); default = NODE_ENV !== production
ENABLE_SWAGGER=

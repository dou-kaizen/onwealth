# NestJS API environment variables
# Copy this file to .env and fill in all REQUIRED values before starting the app.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (postgresql:// scheme required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/onwealth"

# Redis connection string (redis:// for local dev; rediss:// required in production)
REDIS_URL="redis://localhost:6379"

# JWT signing secret — min 32 chars; must not use this placeholder in production
JWT_SECRET=your-secret-key-change-me-in-production-min-32-chars

# API base URL used as the type URI prefix for RFC 9457 Problem Details responses
# Must not be api.example.com in production
API_BASE_URL="http://localhost:3000"

# ── OPTIONAL (defaults shown) ────────────────────────────────────────────────

# Application port (default: 3000)
# PORT=3000

# CORS allowed origins — required in production; comma-separated for multiple
# ALLOWED_ORIGINS=https://your-frontend.com

# Database connection pool
# DB_POOL_MAX=20
# DB_POOL_MIN=5
# DB_POOL_IDLE_TIMEOUT=30000
# DB_POOL_CONNECTION_TIMEOUT=10000

# Redis TTL in seconds (default: 3600)
# REDIS_TTL=3600

# Optional dedicated Redis URL for BullMQ queues.
# Falls back to REDIS_URL when absent. Use rediss:// in production.
# QUEUE_REDIS_URL=redis://localhost:6379

# Rate limiting — max requests per window; must be ≤ 10 000 in production
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100

# OAuth (optional; login disabled when not set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# OAUTH_CALLBACK_BASE_URL=http://localhost:3000/api/auth/oauth
# FRONTEND_URL=http://localhost:8080
